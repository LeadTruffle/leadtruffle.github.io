---
import {
  PRIVACY_POLICY_URL,
  REAL_SITE_URL,
  RSS_FEED_URL,
  SITEMAP_URL,
  TERMS_OF_SERVICE_URL,
  withBase,
} from '../consts'
---

<footer class="site-footer">
  <div class="shell site-footer__grid">
    <div>
      <p class="footer__eyebrow">LeadTruffle Demo Lab</p>
      <p class="footer__copy">
        Built as a lightweight showcase for widgets, lead-routing ideas, and interview PR
        experiments.
      </p>
      <a class="footer__site-link" href={REAL_SITE_URL}>See the full production site at leadtruffle.co</a>
    </div>

    <div>
      <p class="footer__heading">Explore</p>
      <div class="footer__links">
        <a href={withBase('/widgets/')}>Widgets</a>
        <a href={withBase('/playground/')}>Playground</a>
        <a href={withBase('/features/')}>Features</a>
      </div>
    </div>

    <div>
      <p class="footer__heading">Popular flows</p>
      <div class="footer__links">
        <a href={withBase('/features/yelp/')}>Yelp</a>
        <a href={withBase('/features/thumbtack/')}>Thumbtack</a>
        <a href={withBase('/features/google-lsa/')}>Google LSA</a>
      </div>
    </div>
  </div>

  <div class="shell site-footer__bottom">
    <span>LeadTruffle Demo Lab</span>
    <div class="site-footer__legal">
      <a href={PRIVACY_POLICY_URL}>Privacy Policy</a>
      <a href={TERMS_OF_SERVICE_URL}>Terms of Service</a>
      <a href={SITEMAP_URL}>Sitemap</a>
      <a href={RSS_FEED_URL}>RSS</a>
    </div>
  </div>
</footer>
